{
  "manifest_version": 3,
  "name": "FindJobApp Capture",
  "version": "0.1.0",
  "description": "Capture visible hiring post text and send it to FindJobApp.",
  "action": {
    "default_title": "Send to FindJobApp",
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ]
}
